rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'administrador@sesipe.com.br';
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getUserData().role == 'Admin');
    }

    function isSchoolOperator(schoolId) {
      return isSignedIn() && 
        getUserData().role == 'SchoolOperator' && 
        getUserData().schoolId == schoolId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidSchool(data) {
      return data.keys().hasAll(['name', 'city']) &&
             data.name is string && data.name.size() <= 200 &&
             data.city is string && data.city.size() <= 100;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['schoolId', 'courseId', 'grade', 'slots', 'enrolledCount', 'active']) &&
             data.schoolId is string &&
             data.courseId is string &&
             data.grade is string &&
             data.slots is int &&
             data.enrolledCount is int &&
             data.active is bool;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'guardianName', 'email', 'phone', 'schoolId', 'courseId', 'grade', 'status', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.guardianName is string && data.guardianName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.schoolId is string &&
             data.courseId is string &&
             data.grade is string &&
             data.status in ['New', 'Contacted', 'Interested', 'Enrolled', 'Cancelled'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // --- Collection Rules ---

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schoolOffers/{offerId} {
      // Public can see active ones to check for vacancies
      allow list: if isAdmin() || 
                    (isSignedIn() && isSchoolOperator(resource.data.schoolId)) ||
                    resource.data.active == true;
      
      allow get: if isAdmin() || 
                   (isSignedIn() && isSchoolOperator(resource.data.schoolId)) ||
                   resource.data.active == true;

      allow create: if isAdmin() || (isSignedIn() && isSchoolOperator(incoming().schoolId));
      
      allow update: if isAdmin() || 
                      (isSignedIn() && isSchoolOperator(existing().schoolId) && incoming().schoolId == existing().schoolId) ||
                      // Allow landing page to increment enrolledCount
                      (incoming().diff(existing()).affectedKeys().hasOnly(['enrolledCount', 'updatedAt']) && incoming().enrolledCount == existing().enrolledCount + 1);
      
      allow delete: if isAdmin() || (isSignedIn() && isSchoolOperator(existing().schoolId));
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming());
      
      allow get: if isAdmin() || (isSignedIn() && isSchoolOperator(resource.data.schoolId));
      allow list: if isAdmin() || (isSignedIn() && isSchoolOperator(resource.data.schoolId));

      allow update: if (isAdmin() || (isSignedIn() && isSchoolOperator(existing().schoolId))) && 
                      incoming().updatedAt == request.time &&
                      incoming().schoolId == existing().schoolId;
      
      allow delete: if isAdmin();
    }

    match /userRoles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
