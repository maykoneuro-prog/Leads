{
  "entities": {
    "School": {
      "title": "School",
      "description": "A SESI school unit in Pernambuco",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "offeredCourses": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "Course": {
      "title": "Course",
      "description": "An educational offering (e.g., Ensino Fundamental)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "grades": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SchoolOffer": {
      "title": "School Offer",
      "description": "Specific course/grade offering by a school with vacancy control",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "courseId": { "type": "string" },
        "grade": { "type": "string" },
        "slots": { "type": "integer" },
        "enrolledCount": { "type": "integer" },
        "active": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "courseId", "grade", "slots", "enrolledCount"]
    },
    "Lead": {
      "title": "Interest Lead",
      "description": "Information provided by a person interested in enrollment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "guardianName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "schoolId": { "type": "string" },
        "courseId": { "type": "string" },
        "grade": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["New", "Contacted", "Interested", "Enrolled", "Cancelled"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "logs": { "type": "array" }
      },
      "required": ["name", "email", "phone", "schoolId", "courseId", "grade", "status"]
    },
    "UserRole": {
      "title": "User Role",
      "description": "System user roles and school affiliation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "SchoolOperator", "Viewer"] },
        "schoolId": { "type": "string", "description": "Affiliated school ID, if any" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "schools": {
      "schema": "School",
      "description": "List of SESI PE units"
    },
    "courses": {
      "schema": "Course",
      "description": "List of educational levels offered"
    },
    "schoolOffers": {
      "schema": "SchoolOffer",
      "description": "Specific offerings per school"
    },
    "leads": {
      "schema": "Lead",
      "description": "Capture of interested parties"
    },
    "userRoles": {
      "schema": "UserRole",
      "description": "RBAC mapping for system users"
    }
  }
}
